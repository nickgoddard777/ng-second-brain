{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(grep:*)",
      "Bash(git commit:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = \"Darwin\" ]; then bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-commit-macos.sh; else bash \"C:/Users/Nick.Goddard/OneDrive - Acora Limited/Documents/GitHub/ng-second-brain/.claude/hooks/auto-commit.sh\"; fi",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/Nick.Goddard/OneDrive - Acora Limited/Documents/GitHub/ng-second-brain/.claude/hooks/stop-sound.sh\""
          }
        ]
      }
    ]
  }
}
