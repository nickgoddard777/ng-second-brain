views:
  - type: table
    name: Table
    filters:
      and:
        - file.path != this.file.path
        - type == "task"
        - '!status.contains("complete")'
    groupBy:
      property: project
      direction: ASC
    order:
      - file.name
      - due
      - status
      - tags
      - work-personal
      - file.mtime
      - created
    sort:
      - property: due
        direction: ASC
