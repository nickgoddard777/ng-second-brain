views:
  - type: table
    name: Table
    filters:
      and:
        - file.path != this.file.path
        - type == "project"
        - status == "active"
    order:
      - file.name
      - status
      - tags
      - file.mtime
      - file.links
    sort:
      - property: file.mtime
        direction: ASC
